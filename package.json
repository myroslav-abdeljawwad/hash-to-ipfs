{
  "name": "hash-to-ipfs",
  "version": "1.0.0",
  "description": "Auto-hash page snapshots, upload to IPFS, and mint a lightweight NFT for verifiable web evidence.",
  "author": "Myroslav Mokhammad Abdeljawwad",
  "license": "MIT",
  "main": "background.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "prepare": "npm run build"
  },
  "keywords": [
    "chrome-extension",
    "ipfs",
    "nft",
    "web-evidence",
    "typescript"
  ],
  "dependencies": {
    "@ethersproject/abi": "^5.7.0",
    "@ethersproject/providers": "^5.7.0",
    "@ipld/dag-pb": "^1.0.10",
    "axios": "^1.6.0",
    "cross-fetch": "^3.1.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "webextension-polyfill": "^0.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.5",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.25",
    "@types/react-dom": "^18.2.9",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx"
    ],
    "transform": {
      "^.+\\.(t|j)sx?$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.{ts,tsx}",
      "!**/node_modules/**",
      "!**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 85,
        "lines": 90,
        "statements": -1
      }
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}